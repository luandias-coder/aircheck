generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String?
  phone               String?
  onboardingCompleted Boolean   @default(false)
  checkinPdfMode      String    @default("off") // "off" | "immediate" | "morning"
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  properties           Property[]
  reservations         Reservation[]
  inboundEmails        UserInboundEmail[]
  feedbacks            Feedback[]
  hospitableConnection HospitableConnection?
}

model UserInboundEmail {
  id        String   @id @default(cuid())
  userId    String
  email     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([email])
}

// ─── CONDOMINIUM MODULE ───

model Condominium {
  id              String   @id @default(cuid())
  name            String
  address         String?
  code            String   @unique   // 6-char code (ex: AK3F7B)
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  reportMode      String   @default("dashboard") // "dashboard" | "whatsapp"
  doormanWhatsapp String?  // número WhatsApp informado pelo admin (usado quando reportMode = "whatsapp")
  photoUrl        String?  // logo, fachada ou imagem de identificação do condomínio
  plan            String   @default("pilot") // pilot, basic, pro
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users       CondominiumUser[]
  properties  Property[]

  @@index([code])
}

model CondominiumUser {
  id              String   @id @default(cuid())
  condominiumId   String
  name            String
  email           String
  passwordHash    String
  role            String   @default("porteiro") // admin, sindico, porteiro
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)

  @@unique([condominiumId, email])
  @@index([condominiumId])
  @@index([email])
}

// ─── END CONDOMINIUM MODULE ───

model Property {
  id                    String   @id @default(cuid())
  userId                String
  name                  String
  airbnbRoomId          String?
  unitNumber            String?
  parkingSpot           String?
  includeDocLinks       Boolean  @default(false)
  photoUrl              String?  // foto do imóvel extraída do email do Airbnb
  condominiumId         String?
  whatsappEnabled       Boolean  @default(true) // DEPRECATED — usar Condominium.reportMode
  hospitablePropertyId  String?  // Hospitable Connect: property ID
  hospitableListingId   String?  // Hospitable Connect: listing ID
  // ─── Address (from listing webhook) ───
  addressStreet         String?
  addressApt            String?
  addressCity           String?
  addressState          String?
  addressZipcode        String?
  addressLatitude       Float?
  addressLongitude      Float?
  // ─── Listing details (from listing/reservation webhook) ───
  wifiName              String?  // details.wifi_name
  wifiPassword          String?  // details.wifi_password
  maxCapacity           Int?     // capacity.max
  bedrooms              Int?     // capacity.bedrooms
  bathrooms             Int?     // capacity.bathrooms
  amenities             String?  // JSON array: ["KITCHEN","POOL",...]
  houseRules            String?  // JSON: {"pets_allowed":true,...}
  description           String?  // listing summary/description
  roomType              String?  // entire_home, private_room, etc.
  propertyType          String?  // apartment, house, etc.
  internalCode          String?  // Hospitable private_name (e.g. "!RUA1138")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  condominium   Condominium?  @relation(fields: [condominiumId], references: [id], onDelete: SetNull)
  reservations  Reservation[]
  doormanPhones DoormanPhone[]

  @@unique([userId, name])
  @@index([userId])
  @@index([airbnbRoomId])
  @@index([condominiumId])
  @@index([hospitablePropertyId])
  @@index([hospitableListingId])
}

model DoormanPhone {
  id         String   @id @default(cuid())
  propertyId String
  phone      String
  name       String?
  label      String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Reservation {
  id                      String    @id @default(cuid())
  userId                  String
  propertyId              String
  guestFullName           String
  guestPhone              String?
  guestEmail              String?
  guestPhotoUrl           String?
  guestLocale             String?
  checkInDate             String
  checkInTime             String    @default("15:00")
  checkOutDate            String
  checkOutTime            String    @default("12:00")
  numGuests               Int       @default(1)
  guestAdults             Int?
  guestChildren           Int?
  guestInfants            Int?
  guestPets               Int?
  nights                  Int?
  confirmationCode        String?
  bookedAt                String?
  hostPayment             String?
  payoutAmount            Float?
  payoutCurrency          String?
  financialDetails        String?
  platform                String    @default("airbnb")
  timezone                String?
  airbnbThreadId          String?
  airbnbThreadUrl         String?
  formToken               String    @unique @default(cuid())
  status                  String    @default("pending_form")
  carPlate                String?
  carModel                String?
  source                  String    @default("email")
  hospitableReservationId String?   @unique
  sentToDoormanAt         DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property            @relation(fields: [propertyId], references: [id])
  guests   Guest[]
  messages HospitableMessage[]

  @@index([userId])
  @@index([propertyId])
  @@index([formToken])
  @@index([status])
  @@index([confirmationCode])
  @@index([source])
  @@index([platform])
}

model Guest {
  id              String    @id @default(cuid())
  reservationId   String
  fullName        String
  birthDate       String
  cpf             String?
  rg              String?
  foreign         Boolean   @default(false)
  passport        String?
  rne             String?
  documentUrl     String?
  checkedInAt     DateTime? // porteiro confirmou chegada física
  checkedInById   String?   // CondominiumUser.id que confirmou
  checkedInByName String?   // nome desnormalizado (sobrevive a desativação do porteiro)
  createdAt       DateTime  @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

model InboundEmailLog {
  id            String   @id @default(cuid())
  fromEmail     String
  toEmail       String?
  subject       String?
  textBody      String?
  htmlBody      String?
  rawPayload    String?
  parsedData    String?
  reservationId String?
  status        String   @default("received")
  error         String?
  createdAt     DateTime @default(now())

  @@index([fromEmail])
  @@index([createdAt])
  @@index([status])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  rating    Int
  category  String   @default("sugestao")
  message   String
  adminNote String?
  status    String   @default("new")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([status])
}

// ─── HOSPITABLE CONNECT ───

model HospitableConnection {
  id                    String    @id @default(cuid())
  userId                String    @unique
  accessToken           String
  refreshToken          String
  expiresAt             DateTime?
  hospitableAccountId   String?
  scopes                String?
  status                String    @default("active")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model HospitableMessage {
  id                      String   @id @default(cuid())
  reservationId           String?
  hospitableReservationId String?
  sender                  String   @default("guest")
  senderName              String?
  body                    String
  sentAt                  DateTime @default(now())
  platform                String   @default("airbnb")
  createdAt               DateTime @default(now())

  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([reservationId])
  @@index([hospitableReservationId])
  @@index([sentAt])
}

model WebhookLog {
  id            String   @id @default(cuid())
  source        String   @default("hospitable")
  action        String
  payload       String?
  reservationId String?
  status        String   @default("received")
  error         String?
  createdAt     DateTime @default(now())

  @@index([source])
  @@index([action])
  @@index([createdAt])
  @@index([status])
}
