generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  properties    Property[]
  reservations  Reservation[]
  inboundEmails UserInboundEmail[]
}

model UserInboundEmail {
  id        String   @id @default(cuid())
  userId    String
  email     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([email])
}

model Property {
  id            String   @id @default(cuid())
  userId        String
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations  Reservation[]
  doormanPhones DoormanPhone[]

  @@unique([userId, name])
  @@index([userId])
}

model DoormanPhone {
  id         String   @id @default(cuid())
  propertyId String
  phone      String
  name       String?
  label      String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Reservation {
  id               String    @id @default(cuid())
  userId           String
  propertyId       String
  guestFullName    String
  guestPhone       String?
  checkInDate      String
  checkInTime      String    @default("15:00")
  checkOutDate     String
  checkOutTime     String    @default("12:00")
  numGuests        Int       @default(1)
  nights           Int?
  confirmationCode String?
  hostPayment      String?
  guestMessage     String?
  formToken        String    @unique @default(cuid())
  status           String    @default("pending_form")
  carPlate         String?
  carModel         String?
  sentToDoormanAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property      @relation(fields: [propertyId], references: [id])
  guests   Guest[]

  @@index([userId])
  @@index([propertyId])
  @@index([formToken])
  @@index([status])
}

model Guest {
  id            String   @id @default(cuid())
  reservationId String
  fullName      String
  birthDate     String
  cpf           String?
  rg            String?
  foreign       Boolean  @default(false)
  passport      String?
  rne           String?
  documentUrl   String?
  createdAt     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}
