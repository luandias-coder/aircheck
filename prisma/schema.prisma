generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String?
  phone               String?
  onboardingCompleted Boolean   @default(false)
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  properties    Property[]
  reservations  Reservation[]
  inboundEmails UserInboundEmail[]
  feedbacks     Feedback[]
}

model UserInboundEmail {
  id        String   @id @default(cuid())
  userId    String
  email     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@index([email])
}

// ─── CONDOMINIUM MODULE ───

model Condominium {
  id              String   @id @default(cuid())
  name            String
  address         String?
  code            String   @unique   // 6-char code (ex: AK3F7B)
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  reportMode      String   @default("dashboard") // "dashboard" | "whatsapp"
  doormanWhatsapp String?  // número WhatsApp informado pelo admin (usado quando reportMode = "whatsapp")
  plan            String   @default("pilot") // pilot, basic, pro
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users       CondominiumUser[]
  properties  Property[]

  @@index([code])
}

model CondominiumUser {
  id              String   @id @default(cuid())
  condominiumId   String
  name            String
  email           String
  passwordHash    String
  role            String   @default("porteiro") // admin, sindico, porteiro
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)

  @@unique([condominiumId, email])
  @@index([condominiumId])
  @@index([email])
}

// ─── END CONDOMINIUM MODULE ───

model Property {
  id              String   @id @default(cuid())
  userId          String
  name            String
  airbnbRoomId    String?
  unitNumber      String?
  parkingSpot     String?
  includeDocLinks Boolean  @default(false)
  condominiumId   String?
  whatsappEnabled Boolean  @default(true) // DEPRECATED — usar Condominium.reportMode
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  condominium   Condominium?  @relation(fields: [condominiumId], references: [id], onDelete: SetNull)
  reservations  Reservation[]
  doormanPhones DoormanPhone[]

  @@unique([userId, name])
  @@index([userId])
  @@index([airbnbRoomId])
  @@index([condominiumId])
}

model DoormanPhone {
  id         String   @id @default(cuid())
  propertyId String
  phone      String
  name       String?
  label      String?
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Reservation {
  id               String    @id @default(cuid())
  userId           String
  propertyId       String
  guestFullName    String
  guestPhone       String?
  guestPhotoUrl    String?
  checkInDate      String
  checkInTime      String    @default("15:00")
  checkOutDate     String
  checkOutTime     String    @default("12:00")
  numGuests        Int       @default(1)
  nights           Int?
  confirmationCode String?
  hostPayment      String?
  airbnbThreadId   String?
  airbnbThreadUrl  String?
  formToken        String    @unique @default(cuid())
  status           String    @default("pending_form")
  carPlate         String?
  carModel         String?
  sentToDoormanAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property      @relation(fields: [propertyId], references: [id])
  guests   Guest[]

  @@index([userId])
  @@index([propertyId])
  @@index([formToken])
  @@index([status])
  @@index([confirmationCode])
}

model Guest {
  id            String   @id @default(cuid())
  reservationId String
  fullName      String
  birthDate     String
  cpf           String?
  rg            String?
  foreign       Boolean  @default(false)
  passport      String?
  rne           String?
  documentUrl   String?
  createdAt     DateTime @default(now())

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([reservationId])
}

model InboundEmailLog {
  id            String   @id @default(cuid())
  fromEmail     String
  toEmail       String?
  subject       String?
  textBody      String?
  htmlBody      String?
  rawPayload    String?
  parsedData    String?
  reservationId String?
  status        String   @default("received")
  error         String?
  createdAt     DateTime @default(now())

  @@index([fromEmail])
  @@index([createdAt])
  @@index([status])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  rating    Int
  category  String   @default("sugestao")
  message   String
  adminNote String?
  status    String   @default("new")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([status])
}
